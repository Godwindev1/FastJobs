@page "/FastJobs/recurring"
@implements IDisposable
<PageTitle>FastJobs — Recurring</PageTitle>
<link rel="stylesheet" href="_content/FastJobs.Dashboard/css/Recurring.css" />

<!-- Top bar -->
<header class="recurring-header">
    <div class="header-left">
        <span class="header-title">Recurring Jobs</span>
        <span class="header-badge">RecurringJobModel</span>
    </div>
    <button class="new-recurring-button">
        <span class="new-recurring-icon ms">add</span>New Recurring
    </button>
</header>

<div class="recurring-container">
    <!-- Summary stats -->
    <div class="summary-stats-grid">
        <div class="summary-stat-card">
            <div class="summary-stat-content">
                <div class="summary-stat-label">Active</div>
                <div class="summary-stat-value active">@RecurringJobs.Count(r => r.Status == RecurringJobStatus.Active)</div>
            </div>
            <span class="summary-stat-icon active ms">autorenew</span>
        </div>
        <div class="summary-stat-card">
            <div class="summary-stat-content">
                <div class="summary-stat-label">Disabled</div>
                <div class="summary-stat-value warn">@RecurringJobs.Count(r => r.Status == RecurringJobStatus.Disabled)</div>
            </div>
            <span class="summary-stat-icon warn ms">pause_circle</span>
        </div>
        <div class="summary-stat-card">
            <div class="summary-stat-content">
                <div class="summary-stat-label">Cron</div>
                <div class="summary-stat-value">@RecurringJobs.Count(r => r.ScheduleType == ScheduleType.Cron)</div>
            </div>
            <span class="summary-stat-icon ms">terminal</span>
        </div>
        <div class="summary-stat-card">
            <div class="summary-stat-content">
                <div class="summary-stat-label">Interval</div>
                <div class="summary-stat-value">@RecurringJobs.Count(r => r.ScheduleType == ScheduleType.Interval)</div>
            </div>
            <span class="summary-stat-icon ms">timer</span>
        </div>
    </div>

    <!-- Filter -->
    <div class="filter-section">
        <select class="filter-select" @bind="SelectedStatusFilter">
            <option value="">All Statuses</option>
            <option>Active</option>
            <option>Disabled</option>
            <option>Deleted</option>
        </select>
        <select class="filter-select" @bind="SelectedTypeFilter">
            <option value="">All Types</option>
            <option>Cron</option>
            <option>Interval</option>
        </select>
    </div>

    <!-- Table -->
    <div class="table-wrapper">
        <div class="table-container">
            <table class="recurring-table">
                <thead>
                    <tr>
                        <th>ID / Name</th>
                        <th>Schedule</th>
                        <th>Queue</th>
                        <th>Status</th>
                        <th>Next Run</th>
                        <th>Last Run</th>
                        <th>Last State</th>
                        <th>✓ Runs</th>
                        <th>✗ Fails</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in FilteredRecurringJobs)
                    {
                        <tr>
                            <td>
                                <div class="recurring-name">@job.DisplayName</div>
                                <div class="recurring-id">@job.Id</div>
                            </td>
                            <td>
                                @if (job.ScheduleType == ScheduleType.Cron)
                                {
                                    <span class="cron-expression">@job.CronExpression</span>
                                    <span class="cron-description">@job.CronDescription</span>
                                }
                                else
                                {
                                    <span class="cron-expression">@job.Interval?.ToString(@"hh\:mm\:ss")</span>
                                    <span class="cron-description">Every @job.Interval?.ToString(@"hh\:mm\:ss")</span>
                                }
                            </td>
                            <td><span class="queue-badge">@job.QueueName</span></td>
                            <td><span class="status-badge @(job.Status == RecurringJobStatus.Active ? "active" : job.Status == RecurringJobStatus.Disabled ? "disabled" : "deleted")">@job.Status</span></td>
                            <td class="next-run-time">@(job.NextRunAt?.ToString("MMM dd, HH:mm") ?? "—")</td>
                            <td class="last-run-time">@(job.LastRunAt?.ToString("MMM dd, HH:mm") ?? "—")</td>
                            <td><span class="last-state-badge @(job.LastRunState == JobState.Completed ? "succeeded" : job.LastRunState == JobState.Failed ? "failed" : "unknown")">@(job.LastRunState?.ToString() ?? "—")</span></td>
                            <td class="success-count">@job.SucceededCount.ToString("N0")</td>
                            <td class="failure-count @(job.FailedCount > 0 ? "has-failures" : "")">@job.FailedCount</td>
                            <td>
                                <div class="table-actions">
                                    @if (job.Status == RecurringJobStatus.Active)
                                    {
                                        <button class="action-button pause" title="Pause">pause</button>
                                    }
                                    else
                                    {
                                        <button class="action-button resume" title="Resume">play_arrow</button>
                                    }
                                    <button class="action-button trigger" title="Trigger now">bolt</button>
                                    <button class="action-button delete" title="Delete">delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<RecurringJobModel> RecurringJobs { get; set; } = new();
    private List<RecurringJobModel> FilteredRecurringJobs { get; set; } = new();
    private string SelectedStatusFilter { get; set; } = "";
    private string SelectedTypeFilter { get; set; } = "";

    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        LoadData();
        _timer = new System.Timers.Timer(15000); // Update every 15 seconds
        _timer.Elapsed += (sender, e) => InvokeAsync(() =>
        {
            LoadData();
            StateHasChanged();
        });
        _timer.Start();
    }

    private void LoadData()
    {
        RecurringJobs = GenerateRecurringJobs();
        ApplyFilters();
    }

    private List<RecurringJobModel> GenerateRecurringJobs()
    {
        var random = new Random();
        var jobs = new List<RecurringJobModel>();

        jobs.Add(new RecurringJobModel
        {
            Id = "daily-invoice-export",
            DisplayName = "Daily Invoice Export",
            TypeName = "InvoiceService",
            MethodName = "ExportAsync",
            QueueName = "default",
            ScheduleType = ScheduleType.Cron,
            CronExpression = "0 2 * * *",
            CronDescription = "Every day at 02:00",
            Status = RecurringJobStatus.Active,
            NextRunAt = DateTime.UtcNow.Date.AddDays(1).AddHours(2),
            LastRunAt = DateTime.UtcNow.Date.AddHours(2),
            LastRunState = JobState.Completed,
            SucceededCount = 364,
            FailedCount = 0,
            RegisteredAt = DateTime.UtcNow.AddDays(-365)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "hourly-cache-warm",
            DisplayName = "Hourly Cache Warm",
            TypeName = "CacheService",
            MethodName = "WarmCacheAsync",
            QueueName = "critical",
            ScheduleType = ScheduleType.Cron,
            CronExpression = "0 * * * *",
            CronDescription = "Every hour",
            Status = RecurringJobStatus.Active,
            NextRunAt = DateTime.UtcNow.AddHours(1).AddMinutes(-DateTime.UtcNow.Minute),
            LastRunAt = DateTime.UtcNow.AddHours(-1).AddMinutes(-DateTime.UtcNow.Minute),
            LastRunState = JobState.Completed,
            SucceededCount = 720,
            FailedCount = 2,
            RegisteredAt = DateTime.UtcNow.AddDays(-30)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "sync-crm-contacts",
            DisplayName = "Sync CRM Contacts",
            TypeName = "CrmService",
            MethodName = "SyncAsync",
            QueueName = "default",
            ScheduleType = ScheduleType.Interval,
            Interval = TimeSpan.FromMinutes(15),
            Status = RecurringJobStatus.Active,
            NextRunAt = DateTime.UtcNow.AddMinutes(15 - (DateTime.UtcNow.Minute % 15)).AddSeconds(-DateTime.UtcNow.Second),
            LastRunAt = DateTime.UtcNow.AddMinutes(-15 + (DateTime.UtcNow.Minute % 15)).AddSeconds(-DateTime.UtcNow.Second),
            LastRunState = JobState.Completed,
            SucceededCount = 4320,
            FailedCount = 5,
            RegisteredAt = DateTime.UtcNow.AddDays(-180)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "analytics-rollup",
            DisplayName = "Analytics Rollup",
            TypeName = "AnalyticsService",
            MethodName = "RollupAsync",
            QueueName = "analytics",
            ScheduleType = ScheduleType.Cron,
            CronExpression = "0 0 * * *",
            CronDescription = "Midnight daily",
            Status = RecurringJobStatus.Active,
            NextRunAt = DateTime.UtcNow.Date.AddDays(1),
            LastRunAt = DateTime.UtcNow.Date,
            LastRunState = JobState.Failed,
            SucceededCount = 29,
            FailedCount = 3,
            RegisteredAt = DateTime.UtcNow.AddDays(-30)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "email-digest-weekly",
            DisplayName = "Weekly Email Digest",
            TypeName = "MailService",
            MethodName = "SendDigestAsync",
            QueueName = "default",
            ScheduleType = ScheduleType.Cron,
            CronExpression = "0 8 * * 1",
            CronDescription = "Mondays at 08:00",
            Status = RecurringJobStatus.Disabled,
            NextRunAt = null,
            LastRunAt = DateTime.UtcNow.AddDays(-7),
            LastRunState = JobState.Completed,
            SucceededCount = 52,
            FailedCount = 0,
            RegisteredAt = DateTime.UtcNow.AddDays(-365)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "cleanup-orphaned-files",
            DisplayName = "Cleanup Orphaned Files",
            TypeName = "StorageService",
            MethodName = "CleanupAsync",
            QueueName = "low-priority",
            ScheduleType = ScheduleType.Interval,
            Interval = TimeSpan.FromHours(6),
            Status = RecurringJobStatus.Active,
            NextRunAt = DateTime.UtcNow.AddHours(6 - (DateTime.UtcNow.Hour % 6)).AddMinutes(-DateTime.UtcNow.Minute).AddSeconds(-DateTime.UtcNow.Second),
            LastRunAt = DateTime.UtcNow.AddHours(-6 + (DateTime.UtcNow.Hour % 6)).AddMinutes(-DateTime.UtcNow.Minute).AddSeconds(-DateTime.UtcNow.Second),
            LastRunState = JobState.Completed,
            SucceededCount = 180,
            FailedCount = 1,
            RegisteredAt = DateTime.UtcNow.AddDays(-60)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "heartbeat-check",
            DisplayName = "External Heartbeat Check",
            TypeName = "HealthService",
            MethodName = "CheckHeartbeatAsync",
            QueueName = "critical",
            ScheduleType = ScheduleType.Interval,
            Interval = TimeSpan.FromMinutes(1),
            Status = RecurringJobStatus.Active,
            NextRunAt = DateTime.UtcNow.AddMinutes(1).AddSeconds(-DateTime.UtcNow.Second),
            LastRunAt = DateTime.UtcNow.AddMinutes(-1).AddSeconds(-DateTime.UtcNow.Second),
            LastRunState = JobState.Completed,
            SucceededCount = 21600,
            FailedCount = 4,
            RegisteredAt = DateTime.UtcNow.AddDays(-15)
        });

        jobs.Add(new RecurringJobModel
        {
            Id = "backup-user-db",
            DisplayName = "Backup User Database",
            TypeName = "BackupService",
            MethodName = "BackupAsync",
            QueueName = "default",
            ScheduleType = ScheduleType.Cron,
            CronExpression = "0 3 * * *",
            CronDescription = "Every day at 03:00",
            Status = RecurringJobStatus.Disabled,
            NextRunAt = null,
            LastRunAt = DateTime.UtcNow.AddDays(-1).AddHours(3),
            LastRunState = JobState.Completed,
            SucceededCount = 180,
            FailedCount = 0,
            RegisteredAt = DateTime.UtcNow.AddDays(-180)
        });

        return jobs;
    }

    private void ApplyFilters()
    {
        var filtered = RecurringJobs.AsQueryable();

        if (!string.IsNullOrEmpty(SelectedStatusFilter) && Enum.TryParse<RecurringJobStatus>(SelectedStatusFilter, out var status))
        {
            filtered = filtered.Where(r => r.Status == status);
        }

        if (!string.IsNullOrEmpty(SelectedTypeFilter) && Enum.TryParse<ScheduleType>(SelectedTypeFilter, out var type))
        {
            filtered = filtered.Where(r => r.ScheduleType == type);
        }

        FilteredRecurringJobs = filtered.ToList();
    }

    private string GetStatusPillClass(RecurringJobStatus status) => status switch
    {
        RecurringJobStatus.Active => "pill-green",
        RecurringJobStatus.Disabled => "pill-amber",
        _ => "pill-gray"
    };

    private string GetLastStatePillClass(JobState? state) => state switch
    {
        JobState.Completed => "pill-green",
        JobState.Failed => "pill-red",
        _ => "pill-gray"
    };

    public void Dispose()
    {
        _timer?.Dispose();
    }
}