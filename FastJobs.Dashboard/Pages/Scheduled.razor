@page "/FastJobs/scheduled"
@implements IDisposable
@inject ScheduledJobService ScheduledJobsService

<PageTitle>FastJobs — Scheduled</PageTitle>
<link rel="stylesheet" href="_content/FastJobs.Dashboard/css/Scheduled.css" />

<!-- Top bar -->
<header class="scheduled-header">
    <div class="header-left">
        <span class="header-title">Scheduled Jobs</span>
        <span class="header-badge">ScheduledJobModel</span>
    </div>
    <div class="header-right">
        <span>@ScheduledJobs.Count pending</span>
    </div>
</header>

<div class="scheduled-container">
    <!-- Summary -->
    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-card-label">Total Pending</div>
            <div class="summary-card-value info">@ScheduledJobs.Count</div>
            <div class="summary-card-subtext">awaiting enqueue</div>
        </div>
        <div class="summary-card">
            <div class="summary-card-label">Due &lt; 5 min</div>
            <div class="summary-card-value danger">@ScheduledJobs.Count(j => j.TimeTillScheduledrun.TotalMinutes < 5)</div>
            <div class="summary-card-subtext">imminent</div>
        </div>
        <div class="summary-card">
            <div class="summary-card-label">Due &lt; 1 hr</div>
            <div class="summary-card-value warn">@ScheduledJobs.Count(j => j.TimeTillScheduledrun.TotalMinutes < 60)</div>
            <div class="summary-card-subtext">soon</div>
        </div>
        <div class="summary-card">
            <div class="summary-card-label">Recurring Triggers</div>
            <div class="summary-card-value">@ScheduledJobs.Count(j => j.JobType.Contains("rec", StringComparison.OrdinalIgnoreCase)))</div>
            <div class="summary-card-subtext">IsRecurringTrigger</div>
        </div>
    </div>

    <!-- Timeline view — grouped by urgency bucket -->
    <div class="timeline-section">
        <div class="timeline-title">Upcoming Timeline</div>

        @if (ScheduledJobs.Any(j => j.TimeTillScheduledrun.TotalMinutes < 5))
        {
            <div class="alert-box">
                <span class="alert-icon ms">warning</span>
                <span class="alert-text">@ScheduledJobs.Count(j => j.TimeTillScheduledrun.TotalMinutes < 5) jobs due within 5 minutes</span>
            </div>
        }
    </div>

    <!-- Table -->
    <div class="table-wrapper">
        <div class="table-header-section">
            <span class="table-title">Pending Schedule</span>
            <div class="table-filters">
                <select class="table-filter-select" @bind="SelectedQueueFilter">
                    <option value="">All Queues</option>
                    <option>default</option>
                    <option>critical</option>
                    <option>analytics</option>
                </select>
                <select class="table-filter-select" @bind="SelectedTypeFilter">
                    <option value="">All Jobs</option>
                    <option>Recurring Triggers</option>
                    <option>One-off</option>
                </select>
            </div>
        </div>
        <div class="table-container">
            <table class="scheduled-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Job Name</th>
                        <th>Method</th>
                        <th>Queue</th>
                        <th>Enqueue At</th>
                        <th>Time Until</th>
                        <th>Created</th>
                        <th>Source</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in FilteredScheduledJobs)
                    {
                        <tr>
                            <td class="table-cell-id">#@job.Id</td>
                            <td>
                                <div class="table-cell-name">@job.JobName</div>
                            </td>
                            <td>
                                <div class="table-cell-method">
                                    <span class="table-cell-method-type">@job.TypeName.</span><span class="table-cell-method-name">@job.MethodName</span>
                                </div>
                            </td>
                            <td>
                                <span class="table-cell-queue">@job.QueueName</span>
                            </td>
                            <td class="table-cell-time">@job.EnqueueAt.ToString("HH:mm:ss")</td>
                            <td class="table-cell-until @GetUrgencyClass(job.TimeTillScheduledrun)">@FormatTimeUntil(job.TimeTillScheduledrun)</td>
                            <td class="table-cell-created">@job.CreatedAt.ToString("MMM dd, HH:mm")</td>
                            <td>
                                @if (job.JobType.Contains("rec", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="table-source-badge recurring" title="RecurringJobId: @(job.JobType.Replace("sched_", ""))"><span class="table-source-icon ms">autorenew</span>Recurring</span>
                                }
                                else
                                {
                                    <span class="table-source-badge oneoff">One-off</span>
                                }
                                
                            </td>
                            <td>
                                <div class="table-actions">
                                    <button class="action-button" title="Enqueue now">bolt</button>
                                    <button class="action-button danger" title="Cancel">cancel</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-container">
            <span class="pagination-info">Showing 1–@FilteredScheduledJobs.Count of <strong>@ScheduledJobs.Count</strong></span>
            <div class="pagination-buttons">
                <button class="pagination-button" disabled>‹ Prev</button>
                <button class="pagination-button active">1</button>
                <button class="pagination-button">2</button>
                <button class="pagination-button">Next ›</button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ScheduledJobModel> ScheduledJobs { get; set; } = new();
    private List<ScheduledJobModel> FilteredScheduledJobs { get; set; } = new();
    private string SelectedQueueFilter { get; set; } = "";
    private string SelectedTypeFilter { get; set; } = "";

    private System.Timers.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Timers.Timer(12000); // Update every 12 seconds
        _timer.Elapsed += (sender, e) => InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
        _timer.Start();
    }

    private async Task LoadData()
    {
        ScheduledJobs = await GetSchdeuledJobs();
        ApplyFilters();
    }

    private async Task< List<ScheduledJobModel> > GetSchdeuledJobs()
    {
        return (await ScheduledJobsService.GetAllScheduledJobsAsync()).ToList();
    }

    private void ApplyFilters()
    {
        var filtered = ScheduledJobs.AsQueryable();

        if (!string.IsNullOrEmpty(SelectedQueueFilter))
        {
            filtered = filtered.Where(j => j.QueueName == SelectedQueueFilter);
        }

        if (!string.IsNullOrEmpty(SelectedTypeFilter))
        {
            if (SelectedTypeFilter == "Recurring Triggers")
            {
                filtered = filtered.Where(j => j.JobType.Contains("rec", StringComparison.OrdinalIgnoreCase));
            }
            else if (SelectedTypeFilter == "One-off")
            {
                filtered = filtered.Where(j => !j.JobType.Contains("rec", StringComparison.OrdinalIgnoreCase));
            }
        }

        FilteredScheduledJobs = filtered.OrderBy(j => j.EnqueueAt).ToList();
    }

    private string GetUrgencyClass(TimeSpan until)
    {
        if (until.TotalMinutes < 5) return "soon";
        if (until.TotalMinutes < 60) return "near";
        return "later";
    }

    private string FormatTimeUntil(TimeSpan until)
    {
        if (until.TotalHours >= 1)
        {
            return $"{(int)until.TotalHours}h {(int)until.TotalMinutes % 60}m";
        }
        else if (until.TotalMinutes >= 1)
        {
            return $"{(int)until.TotalMinutes}m {(int)until.TotalSeconds % 60}s";
        }
        else
        {
            return $"{(int)until.TotalSeconds}s";
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}