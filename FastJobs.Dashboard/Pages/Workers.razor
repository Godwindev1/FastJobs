@page "/FastJobs/workers"
@implements IDisposable
@inject WorkerOverviewService WorkerService

<PageTitle>FastJobs — Workers</PageTitle>
<link rel="stylesheet" href="_content/FastJobs.Dashboard/css/Workers.css" />

<!-- Top bar -->
<header class="workers-header">
    <div class="header-left">
        <span class="header-title">Workers</span>
        <span class="header-badge">WorkerOverviewModel · WorkerModel</span>
    </div>
    <div class="header-right">
        <span class="dot green pulse"></span>
        <span>Heartbeat: @(DateTime.Now.Second % 60)s</span>
    </div>
</header>

<div class="workers-container">
    <!-- WorkerOverviewModel summary -->
    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-card-label">Total</div>
            <div class="summary-card-value">@WorkerOverview.TotalWorkers</div>
            <div class="summary-card-subtext">workers</div>
        </div>
        <div class="summary-card">
            <div style="display: flex; align-items: center; gap: 8px;">
                <div class="summary-card-value accent">@WorkerOverview.ActiveWorkers</div>
                <span class="dot green pulse"></span>
            </div>
            <div class="summary-card-label">Active</div>
            <div class="summary-card-subtext">processing jobs</div>
        </div>
        <div class="summary-card">
            <div class="summary-card-value">@WorkerOverview.SleepingWorkers</div>
            <div class="summary-card-label">Sleeping</div>
            <div class="summary-card-subtext">idle / waiting</div>
        </div>
        <div class="summary-card">
            <div class="summary-card-value danger">@WorkerOverview.DeadWorkers</div>
            <div class="summary-card-label">Dead</div>
            <div class="summary-card-subtext">no heartbeat</div>
        </div>
        <div class="summary-card">
            <div class="summary-card-value info">@WorkerOverview.TotalActiveJobs</div>
            <div class="summary-card-label">Active Jobs</div>
            <div class="summary-card-subtext">TotalActiveJobs</div>
        </div>
    </div>

    <!-- Worker table -->
    <div class="worker-table-wrapper">
        <div class="worker-table-header">
            <div class="worker-table-title">Worker Instances</div>
            <div class="worker-filter-section">
                <select class="worker-filter-select" @bind="SelectedStateFilter">
                    <option value="">All States</option>
                    <option>Active</option>
                    <option>Sleeping</option>
                    <option>Dead</option>
                </select>
            </div>
        </div>
        <div class="table-container">
            <table class="workers-table">
                <thead>
                    <tr>
                        <th>Worker</th>
                        <th>State</th>
                        <th>Queues</th>
                        <th>Heartbeat</th>
                        <th>Jobs Done</th>
                        <th>Success %</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var worker in FilteredWorkers)
                    {
                        <tr>
                            <td>
                                <div class="worker-name-column">@worker.WorkerName</div>
                                <div class="worker-id">@worker.WorkerId</div>
                            </td>
                            
                            <td><span class="worker-state-badge @GetStatePillClass(worker.State)">@if (worker.State == WorkerState.Active) {<span class="dot green pulse" style="margin-right:4px"></span>} @worker.State</span></td>
                            <td>
                                <div class="worker-queues">
                                    @foreach (var queue in GetWorkerQueues(worker))
                                    {
                                        <span class="queue-badge">@queue</span>
                                    }
                                </div>
                            </td>

                            
                            <td class="heartbeat @(worker.State == WorkerState.Dead ? "dead" : "")">@FormatHeartbeat(worker.HeartbeatAge)</td>
                            <td class="jobs-processed">@worker.Metrics.JobsProcessed.ToString("N0")</td>
                            <td>
                                <div class="success-rate-cell">
                                    <div class="success-rate-bar">
                                        <div class="success-rate-fill @GetSuccessRateColor(worker.Metrics.SuccessRate)" style="width:@worker.Metrics.SuccessRate%"></div>
                                    </div>
                                    <span class="success-rate-text @GetSuccessRateTextColor(worker.Metrics.SuccessRate)">@worker.Metrics.SuccessRate.ToString("F0")%</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Metrics cards -->
    <div class="metrics-section">
        <div class="metrics-title">Worker Metrics (WorkerMetricsModel)</div>
        <div class="metrics-grid">
            @foreach (var worker in WorkerOverview.Workers.Take(3))
            {
                <div class="metric-card">
                    <div class="metric-card-header">
                        <span class="metric-card-name">@worker.WorkerName</span>
                        <span class="metric-card-badge @GetStatePillClass(worker.State)">@worker.State</span>
                    </div>
                    <div class="metrics-grid-values">
                        <div class="metric-value-container">
                            <div class="metric-value-label">Processed</div>
                            <div class="metric-value-number">@worker.Metrics.JobsProcessed.ToString("N0")</div>
                        </div>
                        <div class="metric-value-container">
                            <div class="metric-value-label">Failed</div>
                            <div class="metric-value-number @(worker.Metrics.JobsFailed > 5 ? "danger" : "subtext")">@worker.Metrics.JobsFailed</div>
                        </div>
                        <div class="metric-value-container">
                            <div class="metric-value-label">Avg Latency</div>
                            <div class="metric-value-number">@worker.Metrics.AvgProcessingLatencyMs.ToString("F0")ms</div>
                        </div>
                    </div>
                    <div class="metric-success-rate-section">
                        <div class="metric-success-rate-label"><span>Success Rate</span><span class="@GetSuccessRateTextColor(worker.Metrics.SuccessRate)">@worker.Metrics.SuccessRate.ToString("F0")%</span></div>
                        <div class="metric-success-rate-bar">
                            <div class="metric-success-rate-fill @GetSuccessRateColor(worker.Metrics.SuccessRate)" style="width:@worker.Metrics.SuccessRate%"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private WorkerOverviewModel WorkerOverview { get; set; } = new();
    private List<WorkerModel> FilteredWorkers { get; set; } = new();
    private string SelectedStateFilter { get; set; } = "";

    private System.Timers.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Timers.Timer(8000); // Update every 8 seconds
        _timer.Elapsed += (sender, e) => InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
        _timer.Start();
    }

    private async Task LoadData()
    {
        WorkerOverview = await GetWorkerOverview();
        ApplyFilters();
    }

    private async Task<WorkerOverviewModel> GetWorkerOverview()
    {
        return await WorkerService.GetWorkersOverviewAsync();
    }

    private void ApplyFilters()
    {
        var filtered = WorkerOverview.Workers.AsQueryable();

        if (!string.IsNullOrEmpty(SelectedStateFilter) && Enum.TryParse<WorkerState>(SelectedStateFilter, out var state))
        {
            filtered = filtered.Where(w => w.State == state);
        }

        FilteredWorkers = filtered.ToList();
    }

    private string GetStatePillClass(WorkerState state) => state switch
    {
        WorkerState.Active => "pill-green",
        WorkerState.Sleeping => "pill-amber",
        WorkerState.Dead => "pill-red",
        _ => "pill-gray"
    };

    private List<string> GetWorkerQueues(WorkerModel worker)
    {
        // For demo, assign queues based on worker
        return worker.WorkerId switch
        {
            "wkr-01" => new List<string> { "default", "critical" },
            "wkr-02" => new List<string> { "default" },
            "wkr-03" => new List<string> { "critical" },
            "wkr-04" => new List<string> { "analytics" },
            "wkr-05" => new List<string> { "low-priority" },
            "wkr-06" => new List<string> { "default", "critical" },
            _ => new List<string> { "default" }
        };
    }

    private string FormatRunTime(TimeSpan? runTime) => runTime.HasValue ? $"{runTime.Value.TotalSeconds:F0}s" : "—";

    private string FormatHeartbeat(TimeSpan age)
    {
        if (age.TotalMinutes < 1) return $"{age.TotalSeconds:F0}s ago";
        if (age.TotalHours < 1) return $"{age.TotalMinutes:F0}m ago";
        return $"{age.TotalHours:F0}h ago";
    }

    private string GetSuccessRateColor(double rate) => rate >= 95 ? "bg-accent" : rate >= 80 ? "bg-warn" : "bg-danger";

    private string GetSuccessRateTextColor(double rate) => rate >= 95 ? "text-accent" : rate >= 80 ? "text-warn" : "text-danger";

    public void Dispose()
    {
        _timer?.Dispose();
    }
}