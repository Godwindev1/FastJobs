@page "/FastJobs"
@implements IDisposable
@inject IJSRuntime JSRuntime
@inject DashboardSummaryService summaryService
@inject JobDetailService jobDetailService

<PageTitle>FastJobs — Overview</PageTitle>
<link rel="stylesheet" href="_content/FastJobs.Dashboard/css/Dashboard.css" />

<!-- Top bar -->
<header class="dashboard-header">
    <div class="header-left">
        <span class="header-title">Overview</span>
        <span class="header-badge">DashboardSummaryModel</span>
    </div>
    <div class="header-right">
        <span class="dot green pulse"></span>
        <span id="genAt">@GeneratedAt</span>
    </div>
</header>

<div class="dashboard-container">
    <!-- Job State Summary -->
    <section>
        <div class="section-title">Job States</div>
        <div class="job-states-grid">
            <div class="state-card">
                <span class="state-card-label">Enqueued</span>
                <span class="state-card-value">@DashboardData.EnqueuedCount</span>
                <div class="state-card-description"><span class="ms text-warn" style="font-size:13px">pending</span><span class="state-card-description-text">queued</span></div>
            </div>
            <div class="state-card">
                <span class="state-card-label">Scheduled</span>
                <span class="state-card-value">@DashboardData.ScheduledCount</span>
                <div class="state-card-description"><span class="ms text-info" style="font-size:13px">event</span><span class="state-card-description-text">future</span></div>
            </div>
            <div class="state-card">
                <span class="state-card-label">Processing</span>
                <span class="state-card-value" style="color: #60a5fa;">@DashboardData.ProcessingCount</span>
                <div class="state-card-description"><span class="dot green pulse"></span><span class="state-card-description-text">running</span></div>
            </div>
            <div class="state-card">
                <span class="state-card-label">Succeeded</span>
                <span class="state-card-value" style="color: #10b981;">@DashboardData.SucceededCount</span>
                <div class="state-card-description"><span class="ms text-accent" style="font-size:13px">check_circle</span><span class="state-card-description-text">done</span></div>
            </div>
            <div class="state-card">
                <span class="state-card-label">Failed</span>
                <span class="state-card-value" style="color: #ef4444;">@DashboardData.FailedCount</span>
                <div class="state-card-description"><span class="ms text-danger" style="font-size:13px">error</span><span class="state-card-description-text">errored</span></div>
            </div>
            <div class="state-card">
                <span class="state-card-label">Retrying</span>
                <span class="state-card-value" style="color: #f59e0b;">@DashboardData.RetryingCount</span>
                <div class="state-card-description"><span class="ms text-warn" style="font-size:13px">refresh</span><span class="state-card-description-text">retry</span></div>
            </div>

            <div class="state-card" style="border-left: 2px solid #10b981;">
                <span class="state-card-label">Total</span>
                <span class="state-card-value">@DashboardData.TotalJobs</span>
                <div class="state-card-description"><span class="ms text-accent" style="font-size:13px">layers</span><span class="state-card-description-text">all time</span></div>
            </div>
        </div>
    </section>

    <!-- Middle Row: Throughput + Workers + Servers -->
    <div class="dashboard-middle-row">
        <!-- Hourly Trend -->
        <div class="throughput-section dashboard-card">
            <div class="card-header">
                <div>
                    <div class="card-title">Hourly Throughput Trend</div>
                    <div class="card-subtitle">ThroughputBucketModel · last 12 hrs</div>
                </div>
                <div class="card-legend">
                    <span class="legend-item"><span class="legend-color-box legend-success"></span>Succeeded</span>
                    <span class="legend-item"><span class="legend-color-box legend-failed"></span>Failed</span>
                    <div style="border-left: 1px solid var(--border); padding-left: 16px; display: flex; flex-direction: column; align-items: flex-end;">
                        <span style="font-size: 18px; font-family: 'IBM Plex Mono', monospace; font-weight: 600; color: var(--text); line-height: 1;">@DashboardData.ThroughputPerMinute.ToString("F1")</span>
                        <span style="font-size: 10px; color: var(--dim);">jobs/min</span>
                    </div>
                </div>
            </div>
            <!-- Chart canvas -->
            <div class="chart-container" id="chart">
                @foreach (var bucket in DashboardData.HourlyTrend)
                {
                    var maxS = DashboardData.HourlyTrend.Max(b => b.SucceededCount);
                    var fh = maxS == 0 ? 0 : Math.Max(2, (int)Math.Round((double)bucket.FailedCount / maxS * 132));
                    var sh = maxS == 0 ? 0 : (int)Math.Round((double)bucket.SucceededCount / maxS * 132);
                    <div class="chart-bar">
                        <div class="chart-bar-failed" style="height:@fh.ToString()px;"></div>
                        <div class="chart-bar-succeeded" style="height:@sh.ToString()px;"></div>
                    </div>
                }
            </div>
            <div class="chart-time-labels">
                <span>12h ago</span><span>6h ago</span><span>now</span>
            </div>
        </div>

        <!-- Worker Cluster -->
        <div class="worker-section dashboard-card flex-column">
            <div class="section-title">Workers</div>
            <div style="display: flex; flex-direction: column; gap: 12px; flex: 1;">
                <div class="metric-row">
                    <span class="metric-label">Total</span>
                    <span class="metric-value">@WorkerData.TotalWorkers</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Active</span>
                    <span class="metric-value accent">@WorkerData.ActiveWorkers</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Sleeping</span>
                    <span class="metric-value dim">@WorkerData.SleepingWorkers</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Dead</span>
                    <span class="metric-value danger">@WorkerData.DeadWorkers</span>
                </div>
            </div>
            <div class="utilization-container">
                <div class="utilization-label">Utilisation</div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width:@UtilizationPercent%"></div>
                </div>
                <div class="progress-text">@UtilizationPercent%</div>
            </div>
        </div>

        <!-- Servers + Last-hour KPIs -->
        <div class="system-section dashboard-card flex-column">
            <div class="section-title">System · Last Hour</div>
            <div style="display: flex; flex-direction: column; gap: 12px; flex: 1;">
                <div class="metric-row">
                    <span class="metric-label">Succeeded/hr</span>
                    <span class="metric-value accent">@DashboardData.SucceededLastHour</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Failed/hr</span>
                    <span class="metric-value danger">@DashboardData.FailedLastHour</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Max Retries</span>
                    <span class="metric-value">@DashboardData.DefaultMaxRetries</span>
                </div>
            </div>
            <div class="success-rate-box">
                <div class="success-rate-label">Success rate (1h)</div>
                <div class="success-rate-value">@SuccessRate.ToString("F1")%</div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Feed -->
    <div class="dashboard-table-wrapper">
        <div class="table-header-section">
            <div class="table-title">Recent Execution Log</div>
            <div class="table-live-indicator">
                <span class="dot green pulse"></span>
                <span>live</span>
            </div>
        </div>
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>Job ID</th>
                    <th>Job Name</th>
                    <th>Queue</th>
                    <th>State</th>
                    <th>Duration</th>
                    <th style="text-align: right;">Started</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in RecentJobs)
                {
                    <tr>
                        <td class="table-row-mono">#@job.Id</td>
                        <td class="table-row-name">@job.JobName</td>
                        <td><span class="table-row-queue">@job.QueueName</span></td>
                        <td><span class="pill @GetStateStyle(job.State)">@job.State</span></td>
                        <td class="table-row-duration">@FormatDuration(job.Duration)</td>
                        <td class="table-row-time table-row-time-right">@job.StartedAt?.ToString("HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private DashboardSummaryModel DashboardData { get; set; } = new();
    private WorkerOverviewModel WorkerData { get; set; } = new();
    private List<JobDetailModel> RecentJobs { get; set; } = new();
    private string GeneratedAt => $"Generated {DateTime.Now.ToString("just now")}";
    private int UtilizationPercent => WorkerData.TotalWorkers == 0 ? 0 : (int)Math.Round((double)WorkerData.ActiveWorkers / WorkerData.TotalWorkers * 100);
    private double SuccessRate => DashboardData.SucceededLastHour + DashboardData.FailedLastHour == 0 ? 0 : (double)DashboardData.SucceededLastHour / (DashboardData.SucceededLastHour + DashboardData.FailedLastHour) * 100;

    private System.Timers.Timer? _timer;

    protected override  async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Timers.Timer(5000); // Update every 5 seconds
        _timer.Elapsed += (sender, e) => InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
        _timer.Start();
    }

     private async Task LoadData()
    {
        DashboardData = await summaryService.GetDashboardSummaryAsync();
        

        WorkerData = new WorkerOverviewModel
        {
            TotalWorkers = DashboardData.ActiveWorkers + DashboardData.SleepingWorkers + DashboardData.DeadWorkers,
            ActiveWorkers = DashboardData.ActiveWorkers,
            SleepingWorkers = DashboardData.SleepingWorkers,
            DeadWorkers = DashboardData.DeadWorkers,
            TotalActiveJobs = DashboardData.ActiveWorkers
        };

        RecentJobs = await GenerateRecentJobs();
    }


    private async Task<List<JobDetailModel>> GenerateRecentJobs()
    {
      return (await jobDetailService.GetAllJobDetailsAsync()).Take(10).ToList();
    }

    private string GetStateStyle(JobState state) => state switch
    {
        JobState.Completed => "bg-[rgba(16,185,129,0.12)] text-[#10b981]",
        JobState.Failed => "bg-[rgba(239,68,68,0.12)] text-[#ef4444]",
        JobState.Processing => "bg-[rgba(96,165,250,0.12)] text-[#60a5fa]",
        JobState.Retrying => "bg-[rgba(245,158,11,0.12)] text-[#f59e0b]",
        _ => "bg-[rgba(115,115,115,0.12)] text-[#a0a0a0]"
    };

    private string FormatDuration(TimeSpan? duration) => duration.HasValue ? $"{duration.Value.TotalSeconds:F1}s" : "—";

    public void Dispose()
    {
        _timer?.Dispose();
    }
}