@page "/FastJobs/jobs"
@implements IDisposable
@inject JobDetailService jobsDetailService
<PageTitle>FastJobs — Jobs</PageTitle>
<link rel="stylesheet" href="_content/FastJobs.Dashboard/css/Jobs.css" />

<!-- Top bar -->
<header class="jobs-header">
    <div class="header-left">
        <span class="header-title">Jobs</span>
        <span class="header-badge">JobDetailModel · PagedResult</span>
    </div>
    <!-- Search -->
    <div class="search-container">
        <span class="search-icon ms">search</span>
        <input type="text" placeholder="Search jobs, IDs…" class="search-input" @bind="SearchQuery" @bind:event="oninput"/>
    </div>
</header>

<div class="jobs-container">
    <!-- Stats row -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-card-label">Enqueued</div>
            <div class="stat-card-value">@JobStats.Enqueued</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Scheduled</div>
            <div class="stat-card-value info">@JobStats.Scheduled</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Processing</div>
            <div style="display: flex; align-items: center; gap: 8px;"><div class="stat-card-value info">@JobStats.Processing</div><span class="dot green pulse"></span></div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Succeeded</div>
            <div class="stat-card-value accent">@JobStats.Succeeded</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Failed</div>
            <div class="stat-card-value danger">@JobStats.Failed</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Retrying</div>
            <div class="stat-card-value warn">@JobStats.Retrying</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Cancelled</div>
            <div class="stat-card-value dim">@JobStats.Cancelled</div>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
        <span class="filter-label">Filter</span>
        <div class="filter-divider"></div>
        <div class="filter-group">
            <span class="filter-text">Queue</span>
            <select class="filter-select" @bind="SelectedQueue">
                <option value="">All Queues</option>
                <option>default</option>
                <option>critical</option>
                <option>analytics</option>
                <option>low-priority</option>
            </select>
        </div>
        <div class="filter-group">
            <span class="filter-text">State</span>
            <select class="filter-select" @bind="SelectedState">
                <option value="">All States</option>
                <option>Enqueued</option>
                <option>Scheduled</option>
                <option>Processing</option>
                <option>Succeeded</option>
                <option>Failed</option>
                <option>Retrying</option>
                <option>Deleted</option>
                <option>Deleted</option>
            </select>
        </div>
        <div class="filter-group">
            <span class="filter-text">Sort</span>
            <select class="filter-select" @bind="SortBy">
                <option>CreatedAt ↓</option>
                <option>CreatedAt ↑</option>
                <option>Duration ↓</option>
                <option>AttemptCount ↓</option>
            </select>
        </div>
        <div class="filter-actions">
            <button class="filter-button filter-button-clear" @onclick="ClearFilters">Clear</button>
            <button class="filter-button filter-button-apply" @onclick="ApplyFilters">Apply</button>
        </div>
    </div>

    <!-- Table -->
    <div class="table-wrapper">
        <div class="table-container">
            <table class="jobs-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Job Name</th>
                        <th>Queue</th>
                        <th>State</th>
                        <th>Created</th>
                        <th>Started</th>
                        <th>Duration</th>
                        <th>Attempts</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in FilteredJobs)
                    {
                        <tr>
                            <td class="table-cell-id">#@job.Id</td>
                            <td class="table-cell-name">@job.JobName</td>
                            <td><span class="table-cell-queue">@job.QueueName</span></td>
                            <td><span class="table-cell-state @GetStatePillClass(job.State)">@if (job.State == JobState.Processing) {<span class="dot green pulse" style="margin-right:5px"></span>} @job.State</span></td>
                            <td class="table-cell-time">@job.CreatedAt.ToString("MMM dd, HH:mm")</td>
                            <td class="table-cell-time">@(job.StartedAt?.ToString("HH:mm:ss") ?? "—")</td>
                            <td class="table-cell-duration">@FormatDuration(job.Duration)</td>
                            <td class="table-cell-attempts">@job.AttemptCount</td>
                            <td class="table-cell-actions">
                                <button class="table-action-button ms">more_vert</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="pagination-container">
            <span class="pagination-info">Showing 1–@FilteredJobs.Count of <strong>@AllJobs.Count</strong></span>
            <div class="pagination-buttons">
                <button class="pagination-button" disabled>‹ Prev</button>
                <button class="pagination-button active">1</button>
                <button class="pagination-button">2</button>
                <button class="pagination-button">3</button>
                <span style="color: var(--dim); font-size: 11px; padding: 0 4px;">…</span>
                <button class="pagination-button">@TotalPages</button>
                <button class="pagination-button">Next ›</button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<JobDetailModel> AllJobs { get; set; } = new();
    private List<JobDetailModel> FilteredJobs { get; set; } = new();
    private JobStatsModel JobStats { get; set; } = new();

    private string SearchQuery { get; set; } = "";
    private string SelectedQueue { get; set; } = "";
    private string SelectedState { get; set; } = "";
    private string SortBy { get; set; } = "CreatedAt ↓";
    private int TotalPages => (int)Math.Ceiling(AllJobs.Count / 25.0);

    private System.Timers.Timer? _timer;

    protected override  async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Timers.Timer(10000); // Update every 10 seconds
        _timer.Elapsed += (sender, e) => InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
        _timer.Start();
    }

    private async Task LoadData()
    {
        AllJobs = await GetJobs();
        JobStats = CalculateStats(AllJobs);
        ApplyFilters();
    }

    private async Task<List<JobDetailModel>> GetJobs()
    {
       return (await jobsDetailService.GetAllJobDetailsAsync()).ToList();
    }

    private JobStatsModel CalculateStats(List<JobDetailModel> jobs)
    {
        return new JobStatsModel
        {
            Enqueued = jobs.Count(j => j.State == JobState.Enqueued),
            Scheduled = jobs.Count(j => j.State == JobState.Scheduled),
            Processing = jobs.Count(j => j.State == JobState.Processing),
            Succeeded = jobs.Count(j => j.State == JobState.Completed),
            Failed = jobs.Count(j => j.State == JobState.Failed),
            Retrying = jobs.Count(j => j.State == JobState.Retrying),
            Cancelled = jobs.Count(j => j.State == JobState.Deleted)
        };
    }

    private void ApplyFilters()
    {
        var filtered = AllJobs.AsQueryable();

        if (!string.IsNullOrEmpty(SearchQuery))
        {
            filtered = filtered.Where(j => j.JobName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(SelectedQueue))
        {
            filtered = filtered.Where(j => j.QueueName == SelectedQueue);
        }

        if (!string.IsNullOrEmpty(SelectedState) && Enum.TryParse<JobState>(SelectedState, out var state))
        {
            filtered = filtered.Where(j => j.State == state);
        }

        // Simple sorting
        filtered = SortBy switch
        {
            "CreatedAt ↓" => filtered.OrderByDescending(j => j.CreatedAt),
            "CreatedAt ↑" => filtered.OrderBy(j => j.CreatedAt),
            "Duration ↓" => filtered.OrderByDescending(j => j.Duration),
            "AttemptCount ↓" => filtered.OrderByDescending(j => j.AttemptCount),
            _ => filtered.OrderByDescending(j => j.CreatedAt)
        };

        FilteredJobs = filtered.ToList();
    }

    private void ClearFilters()
    {
        SearchQuery = "";
        SelectedQueue = "";
        SelectedState = "";
        SortBy = "CreatedAt ↓";
        ApplyFilters();
    }

    private string GetStatePillClass(JobState state) => state switch
    {
        JobState.Completed => "pill-green",
        JobState.Failed => "pill-red",
        JobState.Processing => "pill-blue",
        JobState.Retrying => "pill-amber",
        JobState.Enqueued => "pill-gray",
        JobState.Scheduled => "pill-blue",
        JobState.Deleted => "pill-gray",
        _ => "pill-gray"
    };

    private string FormatDuration(TimeSpan? duration) => duration.HasValue ? $"{duration.Value.TotalSeconds:F1}s" : "—";

    public void Dispose()
    {
        _timer?.Dispose();
    }

    private class JobStatsModel
    {
        public int Enqueued { get; set; }
        public int Scheduled { get; set; }
        public int Processing { get; set; }
        public int Succeeded { get; set; }
        public int Failed { get; set; }
        public int Retrying { get; set; }
        public int Cancelled { get; set; }
    }
}